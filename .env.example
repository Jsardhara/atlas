# =============================================================================
# ATLAS — Environment Configuration Template
# Copy to .env, then run `python scripts/gen_secrets.py` to fill secrets.
# Secrets marked (auto-generated) are filled by gen_secrets.py — never type
# them by hand.
# =============================================================================

# -----------------------------------------------------------------------------
# Kraken API — required. Paper mode (validate=true) is enforced regardless,
# but live keys are needed for read endpoints (balances, open orders).
# -----------------------------------------------------------------------------
KRAKEN_API_KEY= ***REVOKED***
KRAKEN_API_SECRET=***REVOKED***=
KRAKEN_USE_DEMO=true

# -----------------------------------------------------------------------------
# Postgres + Redis — host-exposed via docker-compose (127.0.0.1).
# -----------------------------------------------------------------------------
POSTGRES_USER=atlas
POSTGRES_PASSWORD=change_me
POSTGRES_DB=atlas
DATABASE_URL=postgresql+asyncpg://atlas:change_me@localhost:5432/atlas

REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# API auth (auto-generated)
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change_me_64_random_chars
API_ADMIN_PASSWORD=change_me
ATLAS_BEARER_TOKEN=

# Jarvis bridge — Atlas terminal posts here for cross-system chat.
# Default targets the Phase 3a endpoint; override if Jarvis runs elsewhere.
JARVIS_CHAT_URL=http://localhost:8765/api/jarvis/terminal

# -----------------------------------------------------------------------------
# Trading rails
# -----------------------------------------------------------------------------
LIVE_TRADING_ENABLED=false
MAX_LEVERAGE=5
DAILY_LOSS_LIMIT_USD=50
MAX_PORTFOLIO_RISK_PCT=0.10

# -----------------------------------------------------------------------------
# Trading universe (all Kraken USD-quoted crypto pairs, two-stage screener)
# -----------------------------------------------------------------------------
ATLAS_CRYPTO_QUOTE=USD
ATLAS_SCREENER_TOP_N=10
ATLAS_SCREENER_INTERVAL_SEC=300
ATLAS_ENABLE_SHORTS=true
ATLAS_MIN_VOLUME_USD_24H=500000

# -----------------------------------------------------------------------------
# Freqtrade engine (in-Docker)
# -----------------------------------------------------------------------------
FREQTRADE_URL=http://localhost:8080
FREQTRADE_USERNAME=freqtrader
FREQTRADE_PASSWORD=SuperSecret1!

# -----------------------------------------------------------------------------
# Optional data sources
# -----------------------------------------------------------------------------
CRYPTOPANIC_API_KEY=
GLASSNODE_API_KEY=
FRED_API_KEY=

# -----------------------------------------------------------------------------
# Remote access (cloudflared tunnel — only used under `remote` profile)
# -----------------------------------------------------------------------------
CF_TUNNEL_TOKEN=

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
ATLAS_PUBLIC_URL=http://localhost:3000
ENVIRONMENT=development
