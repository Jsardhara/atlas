# =============================================================================
# ATLAS — Environment Configuration Template
# Copy this to .env and fill in your values
# =============================================================================

OPENROUTER_API_KEY=sk-or-...

AGENT_COMMANDER_MODEL=deepseek/deepseek-r1:free
AGENT_ORACLE_MODEL=google/gemini-2.0-flash-exp:free
AGENT_GUARDIAN_MODEL=deepseek/deepseek-r1:free
AGENT_TRADER_MODEL=google/gemini-flash-1.5-8b:free
AGENT_SAGE_MODEL=meta-llama/llama-3.3-70b-instruct:free
AGENT_ARCHITECT_MODEL=qwen/qwen-2.5-coder-32b-instruct:free

KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_API_SECRET=your_kraken_api_secret
KRAKEN_USE_DEMO=true

POSTGRES_USER=atlas
POSTGRES_PASSWORD=change_me
POSTGRES_DB=atlas
DATABASE_URL=postgresql+asyncpg://atlas:change_me@postgres:5432/atlas

REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change_me_64_random_chars
API_ADMIN_PASSWORD=change_me

CF_TUNNEL_TOKEN=

LIVE_TRADING_ENABLED=false
MAX_LEVERAGE=5
DAILY_LOSS_LIMIT_USD=50
MAX_PORTFOLIO_RISK_PCT=0.10
COMMANDER_ALERT_THRESHOLD=0.05

FREQTRADE_URL=http://freqtrade:8080
FREQTRADE_USERNAME=freqtrader
FREQTRADE_PASSWORD=SuperSecret1!

CRYPTOPANIC_API_KEY=
GLASSNODE_API_KEY=
FRED_API_KEY=

ATLAS_PUBLIC_URL=http://localhost:3000
ENVIRONMENT=development
